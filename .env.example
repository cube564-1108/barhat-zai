# API-ключи для сверки заказов
# Скопируйте этот файл в .env и вставьте реальные значения

# RetailCRM
# Получить: https://barhatretailcrm.retailcrm.ru → Настройки → Ключи доступа к API → Добавить
RETAILCRM_API_URL=https://barhatretailcrm.retailcrm.ru
RETAILCRM_API_KEY=твой_ключ_сюда

# МойСклад - Вариант 1 (Basic Auth - самый простой!)
# Просто используй свой логин и пароль от МойСклад
MOYSKLAD_API_URL=https://api.moysklad.ru/api/remap/1.2
MOYSKLAD_LOGIN=твой_email_или_логин
MOYSKLAD_PASSWORD=твой_пароль

# МойСклад - Вариант 2 (токен - если Basic Auth не работает)
# Получить: МойСклад → Настройки → Токены → Добавить токен
# MOYSKLAD_TOKEN=твой_токен_сюда
